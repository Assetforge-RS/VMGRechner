<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Grill-Rechner</title>

<style>
  body {
    font-family: -apple-system, BlinkMacSystemFont, Arial, sans-serif;
    margin: 0;
    padding: 16px;
    background: #f4f4f4;
    color: #222;
  }

  .app {
    max-width: 480px;
    margin: auto;
    background: white;
    border-radius: 18px;
    padding: 18px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.12);
  }

  h1 {
    font-size: 24px;
    margin-top: 0;
    text-align: center;
  }

  label {
    font-weight: 600;
    display: block;
    margin-top: 18px;
  }

  input[type="text"],
  input[type="range"] {
    width: 100%;
    font-size: 18px;
  }

  input[type="text"] {
    padding: 12px;
    border-radius: 12px;
    border: 1px solid #ccc;
    box-sizing: border-box;
  }

  .value {
    font-size: 20px;
    font-weight: bold;
    margin-top: 6px;
  }

  .buttons {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-top: 10px;
  }

  button {
    padding: 14px;
    font-size: 16px;
    border-radius: 14px;
    border: none;
    background: #e9e9e9;
    cursor: pointer;
  }

  button.active {
    background: #222;
    color: white;
  }

  .result {
    margin-top: 24px;
    background: #f7f1e8;
    padding: 16px;
    border-radius: 16px;
  }

  .result h2 {
    margin-top: 0;
  }

  .item {
    display: flex;
    justify-content: space-between;
    border-bottom: 1px solid #ddd;
    padding: 10px 0;
    font-size: 18px;
  }

  .small {
    font-size: 13px;
    color: #666;
    margin-top: 12px;
  }
</style>
</head>

<body>

<div class="app">
  <h1>🔥 Grill-Rechner</h1>

  <label>Name</label>
  <input type="text" id="name" placeholder="Dein Name" oninput="calculate()">

  <label>Tage vor Ort</label>
  <input type="range" id="days" min="1" max="14" value="1" oninput="calculate()">
  <div class="value"><span id="daysValue">1</span> Tag(e)</div>

  <label>Weitere Leute, die du mitbringst</label>
  <input type="range" id="people" min="1" max="20" value="1" oninput="calculate()">
  <div class="value"><span id="peopleValue">1</span> Person(en)</div>

  <label>Faktoren</label>
  <div class="buttons">
    <button id="diet" onclick="toggleFactor('diet')">🥗 Diät</button>
    <button id="hungry" onclick="toggleFactor('hungry')">🥩 Hungrig</button>
    <button id="thirsty" onclick="toggleFactor('thirsty')">🍺 Durstig</button>
    <button id="veryHungry" onclick="toggleFactor('veryHungry')">🔥 Sehr hungrig</button>
  </div>

  <div class="result">
    <h2 id="headline">Mengen</h2>

    <div class="item">
      <span>Hüftsteak</span>
      <strong><span id="steak">0</span> kg</strong>
    </div>

    <div class="item">
      <span>Würstchen</span>
      <strong><span id="sausages">0</span> Stück</strong>
    </div>

    <div class="item">
      <span>Bauchspeck</span>
      <strong><span id="bacon">0</span> kg</strong>
    </div>

    <div class="item">
      <span>Bier</span>
      <strong><span id="beer">0</span> Liter</strong>
    </div>

    <div class="small">
      Basis pro Person/Tag: 250 g Steak, 2 Würstchen, 150 g Bauchspeck, 3,5 l Bier.
    </div>
  </div>
</div>

<script>
  const factors = {
    diet: false,
    hungry: false,
    thirsty: false,
    veryHungry: false
  };

  function toggleFactor(factor) {
    factors[factor] = !factors[factor];
    document.getElementById(factor).classList.toggle("active");
    calculate();
  }

  function calculate() {
    const name = document.getElementById("name").value || "Grillfreund";
    const days = Number(document.getElementById("days").value);
    const people = Number(document.getElementById("people").value);

    document.getElementById("daysValue").innerText = days;
    document.getElementById("peopleValue").innerText = people;

    let foodFactor = 1;
    let drinkFactor = 1;

    if (factors.diet) foodFactor *= 0.7;
    if (factors.hungry) foodFactor *= 1.25;
    if (factors.veryHungry) foodFactor *= 1.5;
    if (factors.thirsty) drinkFactor *= 1.35;

    const totalPersons = people;
    const multiplier = days * totalPersons;

    const steakKg = 0.25 * multiplier * foodFactor;
    const sausages = 2 * multiplier * foodFactor;
    const baconKg = 0.15 * multiplier * foodFactor;
    const beerLiters = 3.5 * multiplier * drinkFactor;

    document.getElementById("headline").innerText =
      "Mengen für " + name + " + Gruppe";

    document.getElementById("steak").innerText = steakKg.toFixed(1);
    document.getElementById("sausages").innerText = Math.ceil(sausages);
    document.getElementById("bacon").innerText = baconKg.toFixed(1);
    document.getElementById("beer").innerText = beerLiters.toFixed(1);
  }

  calculate();
</script>

</body>
</html>